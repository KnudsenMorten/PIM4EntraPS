<?xml version="1.0" encoding="utf-8"?>
<!--
  Native Windows App Service host for the PIM4EntraPS Manager.

  The Manager is a Windows PowerShell HttpListener app. App Service has no
  native PowerShell stack, so we run it via httpPlatformHandler: App Service
  launches powershell.exe (Windows PowerShell 5.1 -- System.Data.SqlClient is
  in-box, no driver bundling) on the script, picks a private port in
  %HTTP_PLATFORM_PORT%, and reverse-proxies inbound to it. The Manager binds
  http://localhost:%HTTP_PLATFORM_PORT%/ (see Invoke-Server).

  Why native (not a container): Windows App Service delivers a working managed
  identity token endpoint (IDENTITY_ENDPOINT), so SQL stays MI-only -- no
  secret, no SQL user. The Linux App Service *custom-container* path does not
  inject that endpoint, which is what blocked the container build.

  Deploy layout: the contents of SOLUTIONS/PIM4EntraPS/ are zip-deployed to
  C:\home\site\wwwroot, and this file is copied to the wwwroot ROOT as
  web.config. The script path below is relative to wwwroot.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="powershell.exe"
                  arguments="-NoProfile -ExecutionPolicy Bypass -File &quot;.\tools\pim-manager\Open-PimManager.ps1&quot; -Hosted -NoLaunch"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\..\LogFiles\pim-stdout"
                  startupTimeLimit="120"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <!-- Force hosted mode; PIM_SqlServer / PIM_SqlDatabase come from App
             Service application settings. MI (IDENTITY_ENDPOINT) is injected by
             App Service automatically when a system-assigned identity is on. -->
        <environmentVariable name="PIM_HOSTED" value="1" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
