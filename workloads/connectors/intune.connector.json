{
  "id": "intune",
  "name": "Microsoft Intune (RBAC roles)",
  "auth": "graph",
  "permissionsNeeded": ["DeviceManagementRBAC.Read.All (list)", "DeviceManagementRBAC.ReadWrite.All (apply)"],
  "prerequisites": {
    "noActivationNeeded": "Intune RBAC is ALWAYS on -- no activation prerequisite. The built-in roles are always present (verified 2026-06-12: /beta/deviceManagement/roleDefinitions?$filter=isBuiltIn eq true returns Endpoint Security Manager, Application Manager, Endpoint Privilege Manager, Read Only Operator, School Administrator, Help Desk Operator, Endpoint Privilege Reader, Policy and Profile manager, Intune Role Administrator, Multi Admin Approval Policy Manager). Bind PIM groups directly via /deviceManagement/roleAssignments; only DeviceManagementRBAC.ReadWrite.All is required."
  },
  "api": {
    "baseUrl": "https://graph.microsoft.com/beta",
    "listRoles": {
      "method": "GET",
      "path": "/deviceManagement/roleDefinitions",
      "itemsPath": "value",
      "roleId": "id",
      "roleName": "displayName",
      "roleDescription": "description"
    },
    "listAssignments": {
      "method": "GET",
      "path": "/deviceManagement/roleDefinitions('{roleId}')/roleAssignments",
      "itemsPath": "value",
      "assignmentId": "id",
      "principalIds": "members"
    },
    "getAssignment": {
      "method": "GET",
      "path": "/deviceManagement/roleAssignments/{assignmentId}",
      "principalIds": "members"
    },
    "assign": {
      "method": "POST",
      "path": "/deviceManagement/roleAssignments",
      "body": {
        "displayName": "PIM4EntraPS: {groupTag} -> {roleName}",
        "description": "Managed by PIM4EntraPS workload connector",
        "roleDefinition@odata.bind": "https://graph.microsoft.com/beta/deviceManagement/roleDefinitions('{roleId}')",
        "members": ["{groupId}"],
        "scopeType": "allDevicesAndLicensedUsers"
      }
    },
    "remove": {
      "method": "DELETE",
      "path": "/deviceManagement/roleAssignments/{assignmentId}"
    }
  }
}
