# PIM4EntraPS -- public repo .gitignore
#
# Mirrors the .custom / .locked split: .locked.* ships, .custom.* is
# customer-private and never committed via `git add .` or destroyed by
# `git clean -fd`.

# ---------------------------------------------------------------------------
#  Customer config + filters + naming -- NEVER commit
# ---------------------------------------------------------------------------
config/*.custom.csv
config/*.custom.ps1
launcher/*/LauncherConfig.custom.ps1
launcher/*/launcher.custom.*.ps1

# ---------------------------------------------------------------------------
#  Run output -- regenerated each run, no value in git
# ---------------------------------------------------------------------------
logs/
output/

# ---------------------------------------------------------------------------
#  PIM Manager tenant cache -- regenerated by -RefreshTenantLists,
#  customer-tenant-specific (role names, AU ids, sub ids, mg ids)
# ---------------------------------------------------------------------------
tools/pim-manager/cache/

# ---------------------------------------------------------------------------
#  Local IDE / OS noise
# ---------------------------------------------------------------------------
.vs/
.idea/
*.suo
.DS_Store
Thumbs.db

# CRX build artifact (regenerated by Setup-PimActivator.ps1; never commit)
tools/pim-activator.crx
tools/pim-activator.pem
