# PIM4EntraPS -- public repo .gitignore
#
# Mirrors the .custom / .locked split: .locked.* ships, .custom.* is
# customer-private and never committed via `git add .` or destroyed by
# `git clean -fd`.

# ---------------------------------------------------------------------------
#  Customer config + filters + naming -- NEVER commit
# ---------------------------------------------------------------------------
config/*.custom.csv
config/*.custom.ps1
launcher/*/LauncherConfig.custom.ps1
launcher/*/launcher.custom.*.ps1

# ---------------------------------------------------------------------------
#  Run output -- regenerated each run, no value in git
# ---------------------------------------------------------------------------
logs/
output/

# ---------------------------------------------------------------------------
#  PIM Manager tenant cache -- regenerated by -RefreshTenantLists,
#  customer-tenant-specific (role names, AU ids, sub ids, mg ids)
# ---------------------------------------------------------------------------
tools/pim-manager/cache/

# PIM Manager MSP instance registry -- maps instance names to per-customer
# config roots on the operator's box. NEVER commit (customer names + paths).
tools/pim-manager/instances.custom.json

# ---------------------------------------------------------------------------
#  Live-test state files -- per-run object ids + tenant/SPN inputs + expected
#  sets (NO secrets, but tenant ids / object ids); regenerated each run.
# ---------------------------------------------------------------------------
tests/live/pimlab-state.json
tests/live/pimscenario-state.json

# ---------------------------------------------------------------------------
#  Local IDE / OS noise
# ---------------------------------------------------------------------------
.vs/
.idea/
*.suo
.DS_Store
Thumbs.db

# CRX build artifact (regenerated by Setup-PimActivator.ps1; never commit)
tools/pim-activator.crx
tools/pim-activator.pem

# Tenant catalog cache from any prior Deploy-PimActivator*.ps1 run. NEVER
# commit -- contains a specific tenant's id + app reg clientId, and if
# another operator later runs Deploy-PimActivatorClient.ps1 on a different
# tenant's box with this file present, the wrong tenant's catalog gets
# written to chrome.storage.managed. v2.4.111 made the client script
# auto-discover from live Entra by default; this ignore is the safety net.
tools/pim-activator/discovered-tenant-catalog.json

# Customer-customized mail + admin templates (LIFECYCLE-GOVERNANCE phases 2+)
templates/mail/*.mailtemplate.custom.html
templates/admin/*.admintemplate.custom.json
templates/policy/*.policytemplate.custom.json
config/*.custom.json
config-local/*.custom.json
config-msp/*.custom.json

# Customer license files -- delivered offline, never tracked anywhere
*.pimlicense

config-test/

# Headless GUI validator node deps (Test-PimManagerGuiComprehensive.ps1).
# Installed locally / in the CI gui job via `cd tests/gui-headless ; npm install`;
# the validator self-skips when absent. The harness .js IS committed.
tests/gui-headless/node_modules/

# ---------------------------------------------------------------------------
#  Playwright GUI feature-suite -- deps, reports, traces, and the per-run sidecar
#  (token + pid) are all regenerated; never commit.
# ---------------------------------------------------------------------------
tests/playwright/feature-suite/node_modules/
tests/playwright/feature-suite/package-lock.json
tests/playwright/feature-suite/playwright-report/
tests/playwright/feature-suite/test-results/
tests/playwright/feature-suite/harness/.manager.json
tests/playwright/feature-suite/harness/.manager.json.*
tests/playwright/feature-suite/harness/.*.json
