      { "GroupName": "PIM-AzRes-Subscription-Contributor-L3-T1-MP-ID", "GroupDescription": "Azure RBAC - Contributor at a subscription (manage resources, cannot grant access)", "GroupTag": "AzRes-Subscription-Contributor-L3", "AdministrativeUnitTag": "PIM-L1", "IsRoleAssignable": "FALSE", "Workload": "Azure-RBAC", "Level": "L3", "TierLevel": "T1", "Plane": "MP", "CPPlatform": "ID", "Owners": "" },
      { "GroupName": "PIM-AzRes-Subscription-Owner-L2-T1-MP-ID", "GroupDescription": "Azure RBAC - Owner at a subscription (full access including RBAC management)", "GroupTag": "AzRes-Subscription-Owner-L2", "AdministrativeUnitTag": "PIM-L1", "IsRoleAssignable": "FALSE", "Workload": "Azure-RBAC", "Level": "L2", "TierLevel": "T1", "Plane": "MP", "CPPlatform": "ID", "Owners": "" },
      { "GroupName": "PIM-AzRes-Subscription-UserAccessAdministrator-L2-T1-MP-ID", "GroupDescription": "Azure RBAC - User Access Administrator at a subscription (manage RBAC assignments only)", "GroupTag": "AzRes-Subscription-UserAccessAdministrator-L2", "AdministrativeUnitTag": "PIM-L1", "IsRoleAssignable": "FALSE", "Workload": "Azure-RBAC", "Level": "L2", "TierLevel": "T1", "Plane": "MP", "CPPlatform": "ID", "Owners": "" }
